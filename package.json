{
  "name": "cnii-banco-de-dados-servico-replicacao",
  "version": "1.0.0",
  "description": "Replicação de Banco de Dados com Separação de Leitura e Escrita",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "npm run db:push && nodemon src/server.js",
    "script": "node src/simulator.js",
    "simulator": "node src/simulator.js",
    "db:generate": "prisma generate",
    "db:push": "node scripts/setup-db.js",
    "db:migrate": "prisma migrate deploy",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.2",
    "prisma": "^5.14.0"
  }
}
